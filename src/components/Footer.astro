---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['footer'];
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
const base    = `/${lang}`;
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';
---

<footer class="border-t border-slate-200 dark:border-white/[0.07] bg-slate-100 dark:bg-navy">
  <div class="section-container pt-20 pb-16">
    <div class="grid md:grid-cols-4 gap-8 lg:gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-2.5 mb-4 w-fit">
          <img src="/logo-mark.svg" alt="" class="w-7 h-7" />
          <span class="font-bold text-slate-900 dark:text-white text-[15px] tracking-tight">
            Strategic<span class="text-brand-500 dark:text-brand-400">Decision</span><span class="text-brand-400/60 text-xs font-normal">.ai</span>
          </span>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed max-w-xs">{t.tagline}</p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 uppercase tracking-wider mb-4">{t.product}</h4>
        <ul class="space-y-2.5">
          <li><a href={`${base}/#features`}  class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.features}</a></li>
          <li><a href={`${base}/pricing/`}   class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.pricing}</a></li>
          <li><a href={`${base}/#`}          class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.changelog}</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 uppercase tracking-wider mb-4">{t.company}</h4>
        <ul class="space-y-2.5">
          <li><a href={`${base}/#`}                       class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.about}</a></li>
          <li><a href="mailto:hello@strategicdecision.ai" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.contact}</a></li>
          <li><a href={`${base}/brand/`}                 class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{lang === 'en' ? 'Brand Assets' : 'Recursos de Marca'}</a></li>
          <li><a href={`${APP_URL}/register`}             class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{lang === 'en' ? 'Sign Up' : 'Registro'}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 uppercase tracking-wider mb-4">{t.legal}</h4>
        <ul class="space-y-2.5">
          <li><a href={`${base}/#`} class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.privacy}</a></li>
          <li><a href={`${base}/#`} class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.terms}</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-slate-200 dark:border-white/[0.06] flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-slate-400 text-xs">{t.copyright}</p>
      <p class="text-slate-400/50 text-xs">{t.madeWith}</p>
    </div>
  </div>
</footer>
