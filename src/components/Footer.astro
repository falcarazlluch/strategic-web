---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['footer'];
  lang: 'en' | 'es';
}
const { t, lang } = Astro.props;
const base      = `/${lang}`;
const APP_URL   = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';
const copyright = t.copyright.replace('{year}', new Date().getFullYear().toString());
---

<footer class="border-t border-slate-200 dark:border-white/[0.06] bg-slate-100/80 dark:bg-[#030508]">
  <div class="section-container pt-16 pb-10">
    <div class="grid md:grid-cols-4 gap-8 lg:gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-2.5 mb-4 w-fit group">
          <img src="/logo-mark.svg" alt="" class="w-7 h-7 transition-transform group-hover:scale-105" />
          <span class="font-bold text-slate-900 dark:text-white text-[15px] tracking-tight">
            Strategic<span class="text-indigo-500 dark:text-indigo-400">Decision</span><span class="text-indigo-400/50 text-xs font-normal">.ai</span>
          </span>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed max-w-xs mb-5">{t.tagline}</p>
        <!-- Social links -->
        <div class="flex gap-3">
          <a href="mailto:info@strategicdecision.ai" class="w-8 h-8 rounded-lg border border-slate-200 dark:border-white/[0.08] flex items-center justify-center text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-white/20 transition-all" aria-label="Email">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener" class="w-8 h-8 rounded-lg border border-slate-200 dark:border-white/[0.08] flex items-center justify-center text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-white/20 transition-all" aria-label="LinkedIn">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 uppercase tracking-wider mb-4">{t.product}</h4>
        <ul class="space-y-2.5">
          <li><a href={`${base}/#features`}  class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.features}</a></li>
          <li><a href={`${base}/#pricing`}   class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.pricing}</a></li>
          <li><a href={`${base}/#agency`}    class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.forConsultants}</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 uppercase tracking-wider mb-4">{t.company}</h4>
        <ul class="space-y-2.5">
          <li><a href="mailto:info@strategicdecision.ai" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.contact}</a></li>
          <li><a href={`${APP_URL}/register`}            class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{lang === 'en' ? 'Sign Up' : 'Registro'}</a></li>
          <li><a href={`${base}/#referral-program`}     class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{lang === 'en' ? 'Partner Program' : 'Programa de Referidos'}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 uppercase tracking-wider mb-4">{t.legal}</h4>
        <ul class="space-y-2.5">
          <li><a href={`${base}/privacy/`} class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.privacy}</a></li>
          <li><a href={`${base}/terms/`}   class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">{t.links.terms}</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-slate-200 dark:border-white/[0.05] flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-slate-400 text-xs">{copyright}</p>
      <p class="text-slate-400 text-xs">info@strategicdecision.ai</p>
    </div>
  </div>
</footer>
