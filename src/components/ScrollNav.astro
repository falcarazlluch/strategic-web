---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const sections = lang === 'es'
  ? [
      { id: 'profiles',        label: 'Adaptado a tu perfil' },
      { id: 'features',        label: 'Funcionalidades' },
      { id: 'consulting-model',label: 'Metodología aplicada' },
      { id: 'how-it-works',    label: 'Cómo funciona' },
      { id: 'demo',            label: 'Ver demo' },
      { id: 'agency',          label: 'Para consultoras' },
      { id: 'testimonials',    label: 'Testimonios' },
      { id: 'pricing',         label: 'Planes y precios' },
    ]
  : [
      { id: 'profiles',        label: 'Built for your role' },
      { id: 'features',        label: 'Features' },
      { id: 'consulting-model',label: 'Applied methodology' },
      { id: 'how-it-works',    label: 'How it works' },
      { id: 'demo',            label: 'Watch demo' },
      { id: 'agency',          label: 'For consultants' },
      { id: 'testimonials',    label: 'Testimonials' },
      { id: 'pricing',         label: 'Pricing' },
    ];
---

<!-- Scroll-to-next bar (full-width, bottom, solid bg — all screen sizes) -->
<div
  id="scroll-nav-mobile"
  aria-hidden="true"
  style="
    position:fixed;
    bottom:0;
    left:0;
    right:0;
    z-index:40;
    opacity:0;
    pointer-events:none;
    transition:opacity 0.35s ease, transform 0.35s ease;
    transform:translateY(8px);
    background:#09090b;
    border-top:1px solid rgba(255,255,255,0.08);
    padding:0.625rem 1rem;
    padding-bottom:calc(0.625rem + env(safe-area-inset-bottom));
    display:flex;
    align-items:center;
    justify-content:center;
  "

>
  <button
    id="scroll-nav-mobile-inner"
    style="
      display:flex;
      align-items:center;
      gap:0.5rem;
      background:#6366f1;
      color:white;
      border:none;
      border-radius:9999px;
      padding:0.5rem 1.25rem;
      font-size:0.8rem;
      font-weight:600;
      font-family:inherit;
      cursor:pointer;
      width:100%;
      max-width:20rem;
      justify-content:center;
    "
  >
    <span id="scroll-nav-mobile-label">–</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </button>
</div>

<script define:vars={{ sections }}>
(function () {
  const bar      = document.getElementById('scroll-nav-mobile');
  const barInner = document.getElementById('scroll-nav-mobile-inner');
  const labelEl  = document.getElementById('scroll-nav-mobile-label');

  // Build ordered list of section elements that exist in DOM
  const sectionEls = sections
    .map(s => ({ ...s, el: document.getElementById(s.id) }))
    .filter(s => s.el);

  if (sectionEls.length === 0) return;

  function showBtn(label, targetId) {
    if (!bar || !barInner || !labelEl) return;
    if (labelEl.textContent !== label) labelEl.textContent = label;
    if (barInner.dataset.target !== targetId) barInner.dataset.target = targetId;
    bar.style.opacity = '1';
    bar.style.transform = 'translateY(0)';
    bar.style.pointerEvents = 'auto';
    bar.setAttribute('aria-hidden', 'false');
  }

  function hideBtn() {
    if (!bar) return;
    bar.style.opacity = '0';
    bar.style.transform = 'translateY(8px)';
    bar.style.pointerEvents = 'none';
    bar.setAttribute('aria-hidden', 'true');
  }

  function update() {
    const winH   = window.innerHeight;
    const docH   = document.documentElement.scrollHeight;
    const scrollY = window.scrollY;

    // Hide only when at the very bottom (pricing / footer visible)
    if (scrollY + winH >= docH - 60) { hideBtn(); return; }

    // Find current section: last one whose top is above 55% of viewport
    let current = -1;
    for (let i = 0; i < sectionEls.length; i++) {
      const top = sectionEls[i].el.getBoundingClientRect().top;
      if (top <= winH * 0.55) current = i;
    }

    // When current === -1 we're still in the hero → point to first section
    const nextIdx = current + 1;
    if (nextIdx < sectionEls.length) {
      showBtn(sectionEls[nextIdx].label, sectionEls[nextIdx].id);
    } else {
      hideBtn();
    }
  }

  // Click → smooth scroll to target
  if (barInner) barInner.addEventListener('click', () => {
    const el = document.getElementById(barInner.dataset.target ?? '');
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Throttled scroll listener
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { update(); ticking = false; });
      ticking = true;
    }
  }, { passive: true });

  // Show immediately on load (after a brief paint delay)
  setTimeout(update, 200);
})();
</script>
