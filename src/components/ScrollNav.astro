---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const sections = lang === 'es'
  ? [
      { id: 'profiles',        label: 'Adaptado a tu perfil' },
      { id: 'features',        label: 'Funcionalidades' },
      { id: 'consulting-model',label: 'Metodología aplicada' },
      { id: 'how-it-works',    label: 'Cómo funciona' },
      { id: 'demo',            label: 'Ver demo' },
      { id: 'agency',          label: 'Para consultoras' },
      { id: 'testimonials',    label: 'Testimonios' },
      { id: 'pricing',         label: 'Planes y precios' },
    ]
  : [
      { id: 'profiles',        label: 'Built for your role' },
      { id: 'features',        label: 'Features' },
      { id: 'consulting-model',label: 'Applied methodology' },
      { id: 'how-it-works',    label: 'How it works' },
      { id: 'demo',            label: 'Watch demo' },
      { id: 'agency',          label: 'For consultants' },
      { id: 'testimonials',    label: 'Testimonials' },
      { id: 'pricing',         label: 'Pricing' },
    ];
---

<!-- Floating scroll-to-next button -->
<div
  id="scroll-nav-btn"
  aria-hidden="true"
  style="
    position:fixed;
    bottom:5.5rem;
    left:50%;
    transform:translateX(-50%) translateY(12px);
    z-index:40;
    opacity:0;
    pointer-events:none;
    transition:opacity 0.35s ease, transform 0.35s ease;
  "
>
  <button
    id="scroll-nav-inner"
    style="
      display:flex;
      align-items:center;
      gap:0.5rem;
      background:rgba(99,102,241,0.92);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      color:white;
      border:1px solid rgba(255,255,255,0.15);
      border-radius:9999px;
      padding:0.5rem 1.1rem 0.5rem 1.25rem;
      font-size:0.8rem;
      font-weight:600;
      font-family:inherit;
      cursor:pointer;
      box-shadow:0 8px 28px rgba(99,102,241,0.4);
      white-space:nowrap;
      transition:background 0.2s ease, box-shadow 0.2s ease;
    "
    onmouseenter="this.style.background='rgba(79,70,229,0.95)'"
    onmouseleave="this.style.background='rgba(99,102,241,0.92)'"
  >
    <span id="scroll-nav-label">–</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </button>
</div>

<script define:vars={{ sections }}>
(function () {
  const btn     = document.getElementById('scroll-nav-btn');
  const inner   = document.getElementById('scroll-nav-inner');
  const labelEl = document.getElementById('scroll-nav-label');
  if (!btn || !inner || !labelEl) return;

  // Build ordered list of section elements that exist in DOM
  const sectionEls = sections
    .map(s => ({ ...s, el: document.getElementById(s.id) }))
    .filter(s => s.el);

  if (sectionEls.length === 0) return;

  function showBtn(label, targetId) {
    // Only update label/target when they actually change (avoids flicker)
    if (labelEl.textContent !== label) labelEl.textContent = label;
    if (inner.dataset.target !== targetId) inner.dataset.target = targetId;
    btn.style.opacity = '1';
    btn.style.transform = 'translateX(-50%) translateY(0)';
    btn.style.pointerEvents = 'auto';
    btn.setAttribute('aria-hidden', 'false');
  }

  function hideBtn() {
    btn.style.opacity = '0';
    btn.style.transform = 'translateX(-50%) translateY(12px)';
    btn.style.pointerEvents = 'none';
    btn.setAttribute('aria-hidden', 'true');
  }

  function update() {
    const winH   = window.innerHeight;
    const docH   = document.documentElement.scrollHeight;
    const scrollY = window.scrollY;

    // Hide only when at the very bottom (pricing / footer visible)
    if (scrollY + winH >= docH - 60) { hideBtn(); return; }

    // Find current section: last one whose top is above 55% of viewport
    let current = -1;
    for (let i = 0; i < sectionEls.length; i++) {
      const top = sectionEls[i].el.getBoundingClientRect().top;
      if (top <= winH * 0.55) current = i;
    }

    // When current === -1 we're still in the hero → point to first section
    const nextIdx = current + 1;
    if (nextIdx < sectionEls.length) {
      showBtn(sectionEls[nextIdx].label, sectionEls[nextIdx].id);
    } else {
      hideBtn();
    }
  }

  // Click → smooth scroll to target
  inner.addEventListener('click', () => {
    const el = document.getElementById(inner.dataset.target ?? '');
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Throttled scroll listener
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { update(); ticking = false; });
      ticking = true;
    }
  }, { passive: true });

  // Show immediately on load (after a brief paint delay)
  setTimeout(update, 200);
})();
</script>
