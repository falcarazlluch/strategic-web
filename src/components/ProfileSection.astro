---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['profile'];
  lang: 'en' | 'es';
}
const { t } = Astro.props;

const roleIcons: Record<string, string> = {
  ceo: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`,
  cfo: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  cto: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
  consultant: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
};

const gradients = [
  'from-indigo-500 to-violet-500',
  'from-blue-500 to-indigo-500',
  'from-emerald-500 to-teal-500',
  'from-amber-500 to-orange-500',
];
---

<section id="profiles" class="section-padding section-bg-alt relative overflow-hidden">
  <div class="glow-blob w-[500px] h-[500px] bg-indigo-500/[0.06] dark:bg-indigo-600/[0.10] -top-20 -left-20" aria-hidden="true"></div>
  <div class="glow-blob w-[400px] h-[400px] bg-violet-500/[0.05] dark:bg-violet-600/[0.08] bottom-0 right-0" aria-hidden="true"></div>

  <div class="section-container relative z-10">
    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <div class="badge mb-4" style="margin:0 auto 1rem;width:fit-content">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl xl:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-5">
        {t.headline}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">{t.subheadline}</p>
    </div>

    <!-- Role cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {t.roles.map((role, i) => (
        <div class={`card-glass p-6 flex flex-col reveal reveal-delay-${i + 1}`}>
          <!-- Icon -->
          <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${gradients[i]} flex items-center justify-center text-white mb-5 shadow-glow-sm`}>
            <Fragment set:html={roleIcons[role.icon] ?? roleIcons['ceo']} />
          </div>

          <h3 class="text-slate-900 dark:text-white font-bold text-base mb-2">{role.title}</h3>
          <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed flex-1 mb-4">{role.description}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5">
            {role.tags.map((tag) => (
              <span class="text-[11px] font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-100 dark:border-indigo-500/20 rounded-full px-2.5 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
