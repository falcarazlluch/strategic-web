---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['pricing'];
  lang: 'en' | 'es';
}
const { t, lang } = Astro.props;
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';
---

<section id="pricing" class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-dots-pattern opacity-30 dark:opacity-100 pointer-events-none" aria-hidden="true"></div>
  <div class="glow-blob w-[600px] h-[600px] bg-indigo-500/[0.07] dark:bg-indigo-600/[0.12] top-0 right-0" aria-hidden="true"></div>

  <div class="section-container relative z-10">
    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <div class="badge mb-4" style="margin:0 auto 1rem;width:fit-content">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl xl:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4">
        {t.headline}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-lg">{t.subheadline}</p>
    </div>

    <!-- Plans grid -->
    <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-4 lg:gap-5 items-stretch">
      {t.plans.map((plan, i) => (
        plan.price === null ? (
          /* ── Agency card: secondary, visually subdued ── */
          <div class={`reveal reveal-delay-${i + 1} relative flex flex-col rounded-2xl p-5 lg:p-6 transition-all duration-300`}
            style="border:1.5px dashed rgba(148,163,184,0.35);background:rgba(248,250,252,0.5)"
          >
            <!-- Agency header -->
            <div class="mb-4">
              <span class="inline-block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-2">Volumen personalizado</span>
              <h3 class="text-slate-700 dark:text-slate-300 font-bold text-base mb-1">{plan.name}</h3>
              <p class="text-slate-400 dark:text-slate-500 text-xs leading-relaxed">{plan.description}</p>
            </div>

            <!-- "Includes Premium +" banner -->
            <div class="flex items-center gap-2 rounded-xl px-3 py-2.5 mb-4 text-xs font-medium"
              style="background:rgba(99,102,241,0.06);border:1px solid rgba(99,102,241,0.18);color:#818cf8"
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              {lang === 'es' ? 'Todo el plan Premium, más:' : 'Everything in Premium, plus:'}
            </div>

            <!-- Differentiators -->
            <ul class="space-y-2 flex-1 mb-5">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2 text-xs text-slate-500 dark:text-slate-400">
                  <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href="mailto:info@strategicdecision.ai"
              class="text-sm font-semibold py-2.5 rounded-xl text-center transition-all duration-200 btn-outline"
            >
              {plan.cta}
            </a>

            <!-- Disclaimer -->
            <p class="text-center text-slate-400 text-[10px] leading-snug mt-3">
              {lang === 'es'
                ? '¿Necesitas más de 30 informes/mes? Cuéntanos tu caso.'
                : 'Need more than 30 reports/month? Tell us about your case.'}
            </p>
          </div>
        ) : (
          /* ── Regular plan card ── */
          <div
            class={`reveal reveal-delay-${i + 1} relative flex flex-col rounded-2xl p-5 lg:p-6 transition-all duration-300 ${
              plan.featured
                ? 'border-2 border-indigo-500/70 shadow-glow'
                : 'card-glass'
            }`}
            style={plan.featured ? 'background: rgba(99,102,241,0.06)' : ''}
          >
            {plan.featured && plan.badge && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
                <span
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold text-white whitespace-nowrap shadow-glow-sm"
                  style="background: linear-gradient(135deg,#6366f1,#8b5cf6)"
                >
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  {plan.badge}
                </span>
              </div>
            )}

            <!-- Plan name & description -->
            <div class="mb-4" style="min-height:4.25rem">
              <h3 class="text-slate-900 dark:text-white font-bold text-base mb-1">{plan.name}</h3>
              <p class="text-slate-500 dark:text-slate-400 text-xs leading-relaxed">{plan.description}</p>
            </div>

            <!-- Price -->
            <div class="mb-3">
              <div class="flex items-baseline gap-0.5">
                <span class="text-3xl font-extrabold text-slate-900 dark:text-white">{plan.currency}{plan.price}</span>
                <span class="text-slate-400 text-sm">{plan.period}</span>
              </div>
            </div>

            <!-- Capacity indicator -->
            <div class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg mb-4 text-xs font-medium" style="background:rgba(99,102,241,0.08);color:#818cf8;border:1px solid rgba(99,102,241,0.18)">
              <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
              </svg>
              {plan.tokens}
            </div>

            <!-- CTA -->
            <a
              href={`${APP_URL}/register?plan=${plan.name.toLowerCase()}`}
              class={`mb-5 text-sm font-semibold py-2.5 rounded-xl text-center transition-all duration-200 ${
                plan.ctaVariant === 'primary' ? 'btn-primary' : 'btn-outline'
              }`}
            >
              {plan.cta}
            </a>

            <!-- Divider -->
            <div style="height:1px;background:rgba(148,163,184,0.15);margin-bottom:1.25rem" aria-hidden="true"></div>

            <!-- Features -->
            <ul class="space-y-2 flex-1">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2 text-xs text-slate-700 dark:text-slate-300">
                  <svg class="w-3.5 h-3.5 text-indigo-500 dark:text-indigo-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                  {feature}
                </li>
              ))}
              {plan.notIncluded.map((feature) => (
                <li class="flex items-start gap-2 text-xs text-slate-400 dark:text-slate-600">
                  <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        )
      ))}
    </div>
  </div>
</section>
