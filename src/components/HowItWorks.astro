---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['howItWorks'];
}

const { t } = Astro.props;
---

<section id="how-it-works" class="section-padding relative overflow-hidden">

  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="glow-blob w-[400px] h-[400px] bg-brand-500/08 dark:bg-brand-600/10 top-1/2 -translate-y-1/2 -right-48"></div>
  </div>

  <div class="section-container relative z-10">
    <div class="text-center mb-16">
      <div class="badge mb-4 mx-auto w-fit">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4">
        {t.headline}
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">
        {t.subheadline}
      </p>
    </div>

    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div
        class="hidden lg:block absolute top-10 left-0 right-0 h-px"
        style="background: linear-gradient(90deg, transparent 0%, rgba(99,102,241,0.2) 12%, rgba(99,102,241,0.2) 88%, transparent 100%);"
        aria-hidden="true"
      ></div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-4">
        {t.steps.map((step, i) => (
          <div class="relative flex flex-col items-center lg:items-start text-center lg:text-left">
            <div class="relative z-10 flex items-center justify-center w-20 h-20 mb-5 rounded-2xl bg-white dark:bg-navy border border-slate-200 dark:border-white/[0.08] shadow-sm dark:shadow-none group cursor-default hover:border-brand-300 dark:hover:border-brand-500/40 transition-colors duration-300">
              <span class="text-3xl font-black text-gradient leading-none">{step.number}</span>
              {i < 3 && (
                <span class="hidden lg:block absolute -right-[22px] top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-brand-400/40" aria-hidden="true"></span>
              )}
            </div>

            <div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-semibold bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20 mb-3">
              <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
              </svg>
              {step.time}
            </div>

            <h3 class="font-bold text-slate-900 dark:text-white text-base mb-2">{step.title}</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
