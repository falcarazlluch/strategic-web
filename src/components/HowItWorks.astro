---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['howItWorks'];
}
const { t } = Astro.props;
---

<section id="how-it-works" class="section-padding section-bg-alt relative overflow-hidden">
  <div class="glow-blob w-[600px] h-[600px] bg-indigo-500/[0.05] dark:bg-indigo-600/[0.10] top-0 left-1/2 -translate-x-1/2" aria-hidden="true"></div>

  <div class="section-container relative z-10">
    <div class="text-center mb-16 reveal">
      <div class="badge mb-4" style="margin:0 auto 1rem;width:fit-content">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl xl:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-5">
        {t.headline}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">{t.subheadline}</p>
    </div>

    <div class="relative max-w-3xl mx-auto">
      <!-- Vertical connector line -->
      <div class="absolute left-6 top-6 bottom-6 w-px bg-gradient-to-b from-indigo-500/40 via-indigo-500/20 to-transparent hidden sm:block" aria-hidden="true"></div>

      <div class="space-y-4">
        {t.steps.map((step, i) => (
          <div class={`reveal reveal-delay-${i + 1} flex gap-5 items-start`}>
            <!-- Step number -->
            <div class="relative flex-shrink-0">
              <div class={`step-number shadow-glow-sm ${step.isSetup ? 'bg-indigo-500/20 dark:bg-indigo-500/25 border-indigo-500/50' : ''}`}>
                {step.number}
              </div>
            </div>

            <!-- Content card -->
            <div class={`card-glass p-5 flex-1 ${step.isSetup ? 'border-indigo-300/50 dark:border-indigo-500/30 bg-indigo-50/40 dark:bg-indigo-500/[0.04]' : ''}`}>
              <div class="flex items-start justify-between gap-4 mb-2">
                <h3 class="text-slate-900 dark:text-white font-bold text-base leading-tight">{step.title}</h3>
                <span class={`flex-shrink-0 text-xs font-semibold rounded-full px-3 py-1 whitespace-nowrap border ${
                  step.isSetup
                    ? 'text-indigo-600 dark:text-indigo-300 bg-indigo-100 dark:bg-indigo-500/15 border-indigo-200 dark:border-indigo-500/30'
                    : 'text-indigo-500 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-500/10 border-indigo-100 dark:border-indigo-500/20'
                }`}>
                  {step.time}
                </span>
              </div>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{step.description}</p>

              {/* Report focus pills — shown only on step 02 */}
              {i === 1 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {['Estratégico', 'Táctico', 'Financiero', 'Operativo', 'Riesgos'].map((label, j) => (
                    <span class={`text-[11px] font-medium rounded-full px-2.5 py-0.5 border ${
                      j === 0
                        ? 'text-indigo-700 dark:text-indigo-300 bg-indigo-100 dark:bg-indigo-500/20 border-indigo-200 dark:border-indigo-500/30'
                        : 'text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-white/[0.04] border-slate-200 dark:border-white/10'
                    }`}>
                      {label}
                    </span>
                  ))}
                  <span class="text-[11px] font-medium text-violet-600 dark:text-violet-400 bg-violet-50 dark:bg-violet-500/10 border border-violet-200 dark:border-violet-500/25 rounded-full px-2.5 py-0.5">
                    + combinar en Plus / Premium
                  </span>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
