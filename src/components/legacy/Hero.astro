---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['hero'];
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">

  <!-- Background -->
  <div class="absolute inset-0 bg-grid-pattern bg-grid pointer-events-none opacity-60 dark:opacity-100" aria-hidden="true"></div>
  <div class="glow-blob w-[600px] h-[600px] bg-brand-500/10 dark:bg-brand-600/20 top-[-100px] left-1/2 -translate-x-1/2" aria-hidden="true"></div>
  <div class="glow-blob w-[350px] h-[350px] bg-blue-500/05 dark:bg-blue-600/10 bottom-0 right-0" aria-hidden="true"></div>

  <div class="section-container relative z-10 w-full py-20 sm:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <!-- Badge -->
        <div class="badge mb-6 animate-fade-up w-fit" style="animation-delay:0.05s;opacity:0;animation-fill-mode:forwards">
          <svg class="w-3 h-3 text-brand-500 dark:text-brand-400" fill="currentColor" viewBox="0 0 8 8">
            <circle cx="4" cy="4" r="4"/>
          </svg>
          {t.badge}
        </div>

        <!-- Headline -->
        <h1
          class="text-4xl sm:text-5xl xl:text-6xl font-extrabold leading-[1.08] tracking-tight text-slate-900 dark:text-white mb-6 animate-fade-up"
          style="animation-delay:0.12s;opacity:0;animation-fill-mode:forwards"
        >
          {t.headline.split(' ').slice(0, 3).join(' ')}{' '}
          <span class="text-gradient">{t.headline.split(' ').slice(3, 5).join(' ')}</span>{' '}
          {t.headline.split(' ').slice(5).join(' ')}
        </h1>

        <!-- Subheadline -->
        <p
          class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-8 max-w-xl animate-fade-up"
          style="animation-delay:0.2s;opacity:0;animation-fill-mode:forwards"
        >
          {t.subheadline}
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-wrap gap-3 mb-12 animate-fade-up"
          style="animation-delay:0.28s;opacity:0;animation-fill-mode:forwards"
        >
          <a href="#pricing" class="btn-primary text-base px-7 py-3.5">
            {t.ctaPrimary}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="#how-it-works" class="btn-outline text-base px-7 py-3.5">
            {t.ctaSecondary}
          </a>
        </div>

      </div>

      <!-- Right: App mockup -->
      <div
        class="animate-fade-up hidden lg:block"
        style="animation-delay:0.3s;opacity:0;animation-fill-mode:forwards"
      >
        <div class="relative">
          <div class="absolute inset-0 bg-brand-500/10 rounded-3xl blur-3xl scale-95" aria-hidden="true"></div>

          <div class="relative card-glass rounded-2xl overflow-hidden shadow-glow-lg dark:shadow-glow-lg">
            <!-- Window chrome -->
            <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-200 dark:border-white/[0.07] bg-slate-50/80 dark:bg-white/[0.02]">
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400/80"></span>
                <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
              </div>
              <div class="flex-1 text-center">
                <span class="text-[11px] text-slate-400 font-mono">strategicdecision.ai — report</span>
              </div>
            </div>

            <!-- Report content -->
            <div class="p-6 bg-white dark:bg-transparent">
              <div class="flex items-start justify-between mb-5">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <img src="/logo-mark.svg" alt="" class="w-4 h-4" />
                    <span class="text-[11px] text-brand-500 dark:text-brand-400 font-medium uppercase tracking-wider">Strategic Report</span>
                  </div>
                  <h3 class="text-slate-900 dark:text-white font-bold text-lg leading-tight">{t.mockup.title}</h3>
                  <p class="text-slate-500 text-xs mt-0.5">{t.mockup.subtitle}</p>
                </div>
                <span class="badge text-[10px]">Live</span>
              </div>

              <!-- Progress -->
              <div class="mb-5">
                <div class="flex justify-between items-center mb-1.5">
                  <span class="text-xs text-slate-500">Completion</span>
                  <span class="text-xs font-semibold text-brand-500 dark:text-brand-400">{t.mockup.progress}%</span>
                </div>
                <div class="h-1.5 bg-slate-100 dark:bg-white/[0.06] rounded-full overflow-hidden">
                  <div
                    class="h-full bg-gradient-to-r from-brand-500 to-brand-400 rounded-full"
                    style={`width: ${t.mockup.progress}%`}
                  ></div>
                </div>
              </div>

              <!-- Sections -->
              <div class="space-y-2 mb-5">
                {t.mockup.sections.map((section) => (
                  <div class="flex items-center gap-2.5">
                    {section.done ? (
                      <span class="w-4 h-4 rounded-full bg-brand-500/15 border border-brand-500/40 flex items-center justify-center flex-shrink-0">
                        <svg class="w-2.5 h-2.5 text-brand-500 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                    ) : (
                      <span class="w-4 h-4 rounded-full border border-slate-300 dark:border-white/20 flex-shrink-0 animate-pulse-slow"></span>
                    )}
                    <span class={`text-xs ${section.done ? 'text-slate-700 dark:text-slate-300' : 'text-slate-400 dark:text-slate-500'}`}>
                      {section.label}
                    </span>
                    {!section.done && (
                      <span class="ml-auto text-[10px] text-brand-500/70 dark:text-brand-400/70 font-mono">
                        <span id="typing-dots">...</span>
                      </span>
                    )}
                  </div>
                ))}
              </div>

              <!-- Generating -->
              <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-brand-50 dark:bg-brand-500/[0.08] border border-brand-200 dark:border-brand-500/20">
                <svg class="w-3.5 h-3.5 text-brand-500 dark:text-brand-400 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                <span class="text-[11px] text-brand-600 dark:text-brand-300">{t.mockup.generating}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-slate-50 dark:from-midnight to-transparent pointer-events-none" aria-hidden="true"></div>
</section>

<script>
  const el = document.getElementById('typing-dots');
  if (el) {
    const frames = ['.', '..', '...'];
    let i = 0;
    setInterval(() => { el.textContent = frames[i++ % frames.length]; }, 500);
  }
</script>
