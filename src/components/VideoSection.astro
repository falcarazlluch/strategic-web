---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['video'];
  lang: 'en' | 'es';
}
const { t } = Astro.props;
const VIDEO_ID = import.meta.env.PUBLIC_DEMO_VIDEO_ID ?? '';
---

<section id="demo" class="section-padding relative overflow-hidden">
  <div class="glow-blob w-[600px] h-[600px] bg-indigo-500/[0.07] dark:bg-indigo-600/[0.12] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>

  <div class="section-container relative z-10">
    <div class="text-center mb-12 reveal">
      <div class="badge mb-4" style="margin:0 auto 1rem;width:fit-content">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4">
        {t.headline}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">{t.subheadline}</p>
    </div>

    <div class="reveal-scale max-w-4xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden shadow-glow-lg" style="padding-top:56.25%">
        {VIDEO_ID ? (
          <iframe
            class="absolute inset-0 w-full h-full"
            src={`https://www.youtube-nocookie.com/embed/${VIDEO_ID}?rel=0&modestbranding=1&color=white`}
            title={t.headline}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        ) : (
          <!-- Placeholder when no video ID -->
          <div class="absolute inset-0 flex flex-col items-center justify-center bg-slate-900 dark:bg-slate-950 border border-indigo-500/20">
            <div class="absolute inset-0 bg-grid-pattern opacity-30" aria-hidden="true"></div>
            <div class="glow-blob w-72 h-72 bg-indigo-500/20 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
            <button
              id="demo-play-btn"
              class="relative z-10 group w-20 h-20 rounded-full bg-indigo-600 hover:bg-indigo-500 shadow-glow-lg flex items-center justify-center transition-all duration-300 hover:scale-110 mb-5"
              aria-label={t.playLabel}
            >
              <svg class="w-8 h-8 text-white translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
              <!-- Pulse rings -->
              <span class="absolute inset-0 rounded-full bg-indigo-500/30 animate-ping" style="animation-duration:2s"></span>
            </button>
            <span class="relative z-10 text-white font-semibold text-lg">{t.playLabel}</span>
            <span class="relative z-10 text-slate-400 text-sm mt-1">{t.duration}</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
