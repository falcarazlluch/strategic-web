---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['video'];
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;

// Set PUBLIC_DEMO_VIDEO_ID to a YouTube video ID to enable the embed
const videoId = import.meta.env.PUBLIC_DEMO_VIDEO_ID ?? '';
---

<section id="demo" class="section-padding relative overflow-hidden section-bg-alt">

  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="glow-blob w-[500px] h-[500px] bg-brand-500/10 dark:bg-brand-600/15 top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2"></div>
  </div>

  <div class="section-container relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="badge mb-4 mx-auto w-fit">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4">
        {t.headline}
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">
        {t.subheadline}
      </p>
    </div>

    <!-- Video container -->
    <div class="max-w-4xl mx-auto">
      <div
        id="video-wrapper"
        class="relative rounded-2xl overflow-hidden shadow-2xl shadow-brand-500/10 dark:shadow-brand-500/20 border border-slate-200 dark:border-white/[0.08] cursor-pointer group"
        style="aspect-ratio: 16/9;"
      >

        {videoId ? (
          /* ── Real YouTube embed ── */
          <iframe
            id="yt-player"
            class="absolute inset-0 w-full h-full"
            src={`https://www.youtube-nocookie.com/embed/${videoId}?rel=0&modestbranding=1&color=white`}
            title={t.headline}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        ) : (
          /* ── Visual placeholder ── */
          <div
            id="video-placeholder"
            class="absolute inset-0 w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-900 via-navy to-slate-900 dark:from-midnight dark:via-navy dark:to-midnight"
          >
            <!-- Animated background grid -->
            <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-20" aria-hidden="true"></div>

            <!-- Glow blobs -->
            <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-brand-600/20 rounded-full blur-3xl" aria-hidden="true"></div>
            <div class="absolute bottom-1/4 right-1/4 w-48 h-48 bg-blue-600/15 rounded-full blur-3xl" aria-hidden="true"></div>

            <!-- Fake report UI in the background -->
            <div class="absolute inset-8 opacity-20 overflow-hidden pointer-events-none" aria-hidden="true">
              <div class="w-full h-full rounded-xl border border-white/10 bg-white/5 p-4 flex gap-3">
                <!-- Sidebar -->
                <div class="w-32 flex-shrink-0 flex flex-col gap-2">
                  {[90, 70, 85, 60, 75, 50].map((w) => (
                    <div class="h-2 rounded bg-white/20" style={`width: ${w}%`}></div>
                  ))}
                </div>
                <!-- Content -->
                <div class="flex-1 flex flex-col gap-2">
                  <div class="h-3 rounded bg-brand-400/40 w-3/4"></div>
                  {[100, 90, 80, 70, 95, 65, 85, 72, 88].map((w) => (
                    <div class="h-1.5 rounded bg-white/15" style={`width: ${w}%`}></div>
                  ))}
                  <div class="mt-2 h-3 rounded bg-brand-400/40 w-1/2"></div>
                  {[80, 70, 90].map((w) => (
                    <div class="h-1.5 rounded bg-white/15" style={`width: ${w}%`}></div>
                  ))}
                </div>
              </div>
            </div>

            <!-- Play button -->
            <div class="relative z-10 flex flex-col items-center gap-4">
              <button
                id="play-btn"
                class="group/play relative w-20 h-20 rounded-full bg-white/10 backdrop-blur-sm border-2 border-white/30 flex items-center justify-center transition-all duration-300 hover:scale-110 hover:bg-brand-500/80 hover:border-brand-400/60 shadow-2xl"
                aria-label={t.playLabel}
              >
                <svg class="w-8 h-8 text-white ml-1 transition-transform group-hover/play:scale-110" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5.14v14l11-7-11-7z"/>
                </svg>
                <!-- Pulse ring -->
                <span class="absolute inset-0 rounded-full border-2 border-white/20 animate-ping" aria-hidden="true"></span>
              </button>
              <div class="text-center">
                <span class="block text-white font-semibold text-sm">{t.playLabel}</span>
                <span class="block text-white/50 text-xs mt-0.5">{t.duration}</span>
              </div>
            </div>

            <!-- Bottom progress bar (decorative) -->
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-white/10">
              <div class="h-full w-0 bg-brand-400" id="progress-bar"></div>
            </div>
          </div>
        )}
      </div>

      <!-- Feature timestamps / highlights below the video -->
      <div class="mt-8 grid sm:grid-cols-3 gap-4">
        {[
          {
            time: '0:00',
            title: lang === 'en' ? 'Problem definition'    : 'Definición del problema',
            desc:  lang === 'en' ? 'Define your challenge in 2 minutes' : 'Define tu desafío en 2 minutos',
            icon:  'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2',
          },
          {
            time: '1:20',
            title: lang === 'en' ? 'AI intake'             : 'Entrevista IA',
            desc:  lang === 'en' ? 'AI asks the right questions' : 'La IA hace las preguntas correctas',
            icon:  'M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z',
          },
          {
            time: '2:05',
            title: lang === 'en' ? 'Report live'           : 'Informe en vivo',
            desc:  lang === 'en' ? 'Full report streaming in real time' : 'Informe completo en tiempo real',
            icon:  'M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6',
          },
        ].map((item) => (
          <div class="card-glass rounded-xl p-4 flex gap-3 hover:border-brand-500/30 transition-colors group/ts">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 rounded-lg bg-brand-50 dark:bg-brand-500/10 border border-brand-200 dark:border-brand-500/20 flex items-center justify-center group-hover/ts:bg-brand-100 dark:group-hover/ts:bg-brand-500/20 transition-colors">
                <svg class="w-4 h-4 text-brand-500 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                </svg>
              </div>
            </div>
            <div>
              <div class="flex items-center gap-2 mb-0.5">
                <span class="text-xs font-mono font-semibold text-brand-500 dark:text-brand-400">{item.time}</span>
                <span class="text-xs font-semibold text-slate-900 dark:text-white">{item.title}</span>
              </div>
              <p class="text-xs text-slate-500 dark:text-slate-500">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

{!videoId && (
  <script>
    // Animate fake progress bar on hover
    const bar  = document.getElementById('progress-bar');
    const wrap = document.getElementById('video-wrapper');
    let anim: number;

    wrap?.addEventListener('mouseenter', () => {
      let w = 0;
      anim = setInterval(() => {
        w = Math.min(w + 0.3, 35);
        if (bar) bar.style.width = w + '%';
      }, 30) as unknown as number;
    });

    wrap?.addEventListener('mouseleave', () => {
      clearInterval(anim);
      if (bar) bar.style.width = '0%';
    });
  </script>
)}
