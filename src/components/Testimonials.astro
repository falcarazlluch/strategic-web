---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['testimonials'];
}

const { t } = Astro.props;
const stars = Array(5).fill(null);
---

<section class="section-padding relative overflow-hidden section-bg-alt">

  <div class="section-container relative z-10">
    <div class="text-center mb-14">
      <div class="badge mb-4 mx-auto w-fit">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">
        {t.headline}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {t.items.map((item) => (
        <div class="card-glass rounded-2xl p-6 flex flex-col gap-4 hover:border-brand-300 dark:hover:border-white/[0.14] hover:shadow-md dark:hover:shadow-none dark:hover:bg-white/[0.05] transition-all duration-300">

          <div class="flex gap-1">
            {stars.map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <blockquote class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed flex-1">
            "{item.quote}"
          </blockquote>

          <div class="flex items-center gap-3 pt-2 border-t border-slate-200 dark:border-white/[0.06]">
            <div class={`w-9 h-9 rounded-full ${item.color} flex items-center justify-center text-white text-xs font-bold flex-shrink-0`}>
              {item.initials}
            </div>
            <div>
              <div class="text-sm font-semibold text-slate-900 dark:text-white">{item.name}</div>
              <div class="text-xs text-slate-500">{item.title} · {item.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
