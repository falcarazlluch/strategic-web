---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['hero'];
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">

  <!-- Background layers -->
  <div class="absolute inset-0 bg-grid-pattern pointer-events-none opacity-50 dark:opacity-100" aria-hidden="true"></div>

  <!-- Animated blobs -->
  <div class="glow-blob w-[700px] h-[700px] bg-indigo-500/[0.08] dark:bg-indigo-600/[0.18] -top-32 left-1/2 -translate-x-1/4 animate-float" style="animation-duration:8s" aria-hidden="true"></div>
  <div class="glow-blob w-[500px] h-[500px] bg-violet-500/[0.06] dark:bg-violet-600/[0.12] top-1/2 -right-24 animate-float" style="animation-duration:10s;animation-delay:2s" aria-hidden="true"></div>
  <div class="glow-blob w-[300px] h-[300px] bg-blue-500/[0.05] dark:bg-blue-600/[0.10] bottom-0 left-0 animate-float" style="animation-duration:12s;animation-delay:4s" aria-hidden="true"></div>

  <div class="section-container relative z-10 w-full py-20 sm:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <!-- Badge -->
        <div
          class="badge mb-6 w-fit animate-fade-up"
          style="animation-delay:0.05s;opacity:0;animation-fill-mode:forwards"
        >
          <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg>
          {t.badge}
        </div>

        <!-- Headline -->
        <h1
          class="text-4xl sm:text-5xl xl:text-[3.4rem] font-extrabold leading-[1.06] tracking-tight text-slate-900 dark:text-white mb-6 animate-fade-up"
          style="animation-delay:0.12s;opacity:0;animation-fill-mode:forwards"
        >
          {t.headline.split(' ').slice(0, 6).join(' ')}{' '}
          <span class="text-gradient">{t.headline.split(' ').slice(6, 9).join(' ')}</span>{' '}
          {t.headline.split(' ').slice(9).join(' ')}
        </h1>

        <!-- Subheadline -->
        <p
          class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-8 max-w-xl animate-fade-up"
          style="animation-delay:0.20s;opacity:0;animation-fill-mode:forwards"
        >
          {t.subheadline}
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-wrap gap-3 mb-12 animate-fade-up"
          style="animation-delay:0.28s;opacity:0;animation-fill-mode:forwards"
        >
          <a href={`${APP_URL}/register`} class="btn-primary text-base px-7 py-3.5">
            {t.ctaPrimary}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="#how-it-works" class="btn-outline text-base px-7 py-3.5">
            {t.ctaSecondary}
          </a>
        </div>

        <!-- Stats -->
        <div
          class="flex flex-wrap gap-6 sm:gap-10 animate-fade-up"
          style="animation-delay:0.36s;opacity:0;animation-fill-mode:forwards"
        >
          {t.stats.map((stat) => (
            <div class="flex flex-col gap-0.5">
              <span class="text-2xl font-bold text-slate-900 dark:text-white">{stat.value}</span>
              <span class="text-xs text-slate-500 uppercase tracking-wider">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: App mockup -->
      <div
        class="animate-fade-up hidden lg:block"
        style="animation-delay:0.22s;opacity:0;animation-fill-mode:forwards"
      >
        <div class="relative">
          <!-- Glow behind card -->
          <div class="absolute inset-0 bg-indigo-500/10 rounded-3xl blur-3xl scale-95 animate-float" style="animation-duration:6s" aria-hidden="true"></div>

          <div class="relative card-glass rounded-2xl overflow-hidden shadow-glow-lg">
            <!-- Window chrome -->
            <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-200 dark:border-white/[0.07] bg-slate-50/80 dark:bg-white/[0.025]">
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-red-400/70"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400/70"></span>
                <span class="w-3 h-3 rounded-full bg-green-400/70"></span>
              </div>
              <div class="flex-1 text-center">
                <span class="text-[11px] text-slate-400 font-mono">strategicdecision.ai — report</span>
              </div>
            </div>

            <!-- Report content -->
            <div class="p-6 bg-white dark:bg-transparent">
              <div class="flex items-start justify-between mb-5">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <img src="/logo-mark.svg" alt="" class="w-4 h-4" />
                    <span class="text-[11px] text-indigo-500 dark:text-indigo-400 font-medium uppercase tracking-wider">Strategic Report</span>
                  </div>
                  <h3 class="text-slate-900 dark:text-white font-bold text-base leading-tight">{t.mockup.title}</h3>
                  <p class="text-slate-500 text-xs mt-0.5">{t.mockup.subtitle}</p>
                </div>
                <span class="badge text-[10px] whitespace-nowrap">Live</span>
              </div>

              <!-- Progress bar -->
              <div class="mb-5">
                <div class="flex justify-between items-center mb-1.5">
                  <span class="text-xs text-slate-500">Completion</span>
                  <span class="text-xs font-semibold text-indigo-500 dark:text-indigo-400">{t.mockup.progress}%</span>
                </div>
                <div class="h-1.5 bg-slate-100 dark:bg-white/[0.06] rounded-full overflow-hidden">
                  <div
                    class="h-full rounded-full animate-gradient"
                    style={`width:${t.mockup.progress}%;background:linear-gradient(90deg,#6366f1,#818cf8,#6366f1);background-size:200%`}
                  ></div>
                </div>
              </div>

              <!-- Sections list -->
              <div class="space-y-2 mb-5">
                {t.mockup.sections.map((section) => (
                  <div class="flex items-center gap-2.5">
                    {section.done ? (
                      <span class="w-4 h-4 rounded-full bg-indigo-500/15 border border-indigo-500/40 flex items-center justify-center flex-shrink-0">
                        <svg class="w-2.5 h-2.5 text-indigo-500 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                    ) : (
                      <span class="w-4 h-4 rounded-full border border-slate-300 dark:border-white/20 flex-shrink-0">
                        <span class="block w-full h-full rounded-full bg-indigo-400/30 animate-pulse"></span>
                      </span>
                    )}
                    <span class={`text-xs ${section.done ? 'text-slate-700 dark:text-slate-300' : 'text-slate-400 dark:text-slate-500'}`}>
                      {section.label}
                    </span>
                  </div>
                ))}
              </div>

              <!-- Generating indicator -->
              <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-indigo-50 dark:bg-indigo-500/[0.08] border border-indigo-200 dark:border-indigo-500/20">
                <svg class="w-3.5 h-3.5 text-indigo-500 dark:text-indigo-400 animate-spin-slow" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                <span class="text-[11px] text-indigo-600 dark:text-indigo-300">{t.mockup.generating}</span>
                <span class="text-[11px] text-indigo-400 ml-auto font-mono animate-blink">|</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-slate-50 dark:from-[#05090f] to-transparent pointer-events-none" aria-hidden="true"></div>
</section>
