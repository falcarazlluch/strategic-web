---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['hero'];
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';

const es = lang === 'es';

// Screen labels (tab indicators above the mockup)
const screenLabels = es
  ? ['01 · Configura tu empresa', '02 · Intake con IA', '03 · Informe en tiempo real']
  : ['01 · Set up your company', '02 · AI Intake', '03 · Report in real time'];

// Screen 1 — Company profile data
const s1 = es ? {
  heading: 'Perfil de empresa',
  name: 'Acme SaaS S.L.',
  sector: 'Tecnología · B2B SaaS',
  model: 'Suscripción · Mercado SME',
  stage: 'Scale-up · Expansión',
  markets: 'España, Francia, Italia',
  role: 'CEO',
  docs: ['Plan estratégico 2024', 'Informe financiero Q3', 'Análisis competitivo'],
  ctxLabel: 'Contexto importado desde web',
} : {
  heading: 'Company profile',
  name: 'Acme SaaS Ltd.',
  sector: 'Technology · B2B SaaS',
  model: 'Subscription · SME market',
  stage: 'Scale-up · Expansion',
  markets: 'Spain, France, Italy',
  role: 'CEO',
  docs: ['Strategic plan 2024', 'Financial report Q3', 'Competitive analysis'],
  ctxLabel: 'Context imported from website',
};

// Screen 2 — Intake Q&A data
const s2 = es ? {
  heading: 'Intake estratégico',
  q1: '¿Cuál es la principal barrera para entrar en el mercado francés: encaje de producto, precio o distribución?',
  a1: 'Distribución, principalmente. No tenemos partners locales y el ciclo de venta directa es demasiado largo.',
  q2: '¿Cuál es tu CAC actual en España vs. el CAC objetivo para Francia?',
  typing: 'Analizando respuesta…',
} : {
  heading: 'AI Strategic Intake',
  q1: 'What is the main barrier to entering the French market — product-market fit, pricing, or distribution?',
  a1: 'Distribution mainly. We have no local partners and direct sales cycles are too long.',
  q2: 'What is your current CAC in Spain vs. your target CAC for France?',
  typing: 'Analysing response…',
};

// Screen 3 uses t.mockup from translations
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">

  <!-- Background -->
  <div class="absolute inset-0 bg-grid-pattern pointer-events-none opacity-50 dark:opacity-100" aria-hidden="true"></div>
  <div class="glow-blob w-[700px] h-[700px] bg-indigo-500/[0.08] dark:bg-indigo-600/[0.18] -top-32 left-1/2 -translate-x-1/4 animate-float" style="animation-duration:8s" aria-hidden="true"></div>
  <div class="glow-blob w-[500px] h-[500px] bg-violet-500/[0.06] dark:bg-violet-600/[0.12] top-1/2 -right-24 animate-float" style="animation-duration:10s;animation-delay:2s" aria-hidden="true"></div>
  <div class="glow-blob w-[300px] h-[300px] bg-blue-500/[0.05] dark:bg-blue-600/[0.10] bottom-0 left-0 animate-float" style="animation-duration:12s;animation-delay:4s" aria-hidden="true"></div>

  <div class="section-container relative z-10 w-full py-8 sm:py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <div class="badge mb-6 w-fit animate-fade-up" style="animation-delay:0.05s;opacity:0;animation-fill-mode:forwards">
          <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg>
          {t.badge}
        </div>

        <h1
          class="text-3xl sm:text-5xl xl:text-[3.4rem] font-extrabold leading-[1.1] tracking-tight text-slate-900 dark:text-white mb-4 sm:mb-6 animate-fade-up"
          style="animation-delay:0.12s;opacity:0;animation-fill-mode:forwards"
        >
          {t.headline.split(' ').slice(0, 6).join(' ')}{' '}
          <span class="text-gradient">{t.headline.split(' ').slice(6, 9).join(' ')}</span>{' '}
          {t.headline.split(' ').slice(9).join(' ')}
        </h1>

        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-5 sm:mb-8 max-w-xl animate-fade-up" style="animation-delay:0.20s;opacity:0;animation-fill-mode:forwards">
          {t.subheadline}
        </p>

        <div class="flex flex-wrap gap-3 mb-6 sm:mb-12 animate-fade-up" style="animation-delay:0.28s;opacity:0;animation-fill-mode:forwards">
          <a href="#pricing" class="btn-primary text-base px-7 py-3.5">
            {t.ctaPrimary}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <button type="button" onclick="if(window.openDemoModal)window.openDemoModal()" class="btn-outline text-base px-7 py-3.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"/>
            </svg>
            {t.ctaSecondary}
          </button>
        </div>

      </div>

      <!-- Right: rotating mockup -->
      <div class="animate-fade-up hidden lg:flex flex-col gap-4" style="animation-delay:0.22s;opacity:0;animation-fill-mode:forwards">

        <!-- Step tab labels -->
        <div class="flex gap-1.5" id="screen-tabs" role="tablist">
          {screenLabels.map((label, i) => (
            <button
              role="tab"
              data-tab={i}
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`screen-tab flex-1 text-[10px] font-semibold rounded-lg px-2 py-1.5 transition-all duration-200 text-center leading-tight ${
                i === 0
                  ? 'bg-indigo-500 text-white shadow-glow-sm'
                  : 'bg-slate-100 dark:bg-white/[0.05] text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300'
              }`}
            >
              {label}
            </button>
          ))}
        </div>

        <!-- Screens wrapper (fixed height, screens stack absolutely inside) -->
        <div class="relative" style="height:390px">

          <!-- Glow behind -->
          <div class="absolute inset-0 bg-indigo-500/10 rounded-3xl blur-3xl scale-95 animate-float" style="animation-duration:6s" aria-hidden="true"></div>

          <!-- ── SCREEN 1: Company setup ── -->
          <div id="screen-0" class="hero-screen absolute inset-0 card-glass rounded-2xl overflow-hidden shadow-glow-lg" style="opacity:1;transform:translateY(0);transition:opacity 0.5s ease,transform 0.5s ease">
            <!-- Chrome -->
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-slate-200 dark:border-white/[0.07] bg-slate-50/80 dark:bg-white/[0.025] flex-shrink-0">
              <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span><span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span></div>
              <span class="flex-1 text-center text-[10px] text-slate-400 font-mono">strategicdecision.ai — company</span>
            </div>
            <!-- Content -->
            <div class="p-5 bg-white dark:bg-transparent h-full overflow-hidden">
              <div class="flex items-center gap-2 mb-4">
                <img src="/logo-mark.svg" alt="" class="w-3.5 h-3.5" />
                <span class="text-[10px] text-indigo-500 dark:text-indigo-400 font-semibold uppercase tracking-wider">{s1.heading}</span>
              </div>
              <!-- Company name -->
              <div class="flex items-center gap-3 mb-4 pb-4 border-b border-slate-100 dark:border-white/[0.06]">
                <div class="w-9 h-9 rounded-xl bg-indigo-500 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">A</div>
                <div>
                  <p class="text-slate-900 dark:text-white font-bold text-sm leading-tight">{s1.name}</p>
                  <p class="text-slate-400 text-[11px]">{s1.sector}</p>
                </div>
                <span class="ml-auto badge text-[9px]">{s1.role}</span>
              </div>
              <!-- Fields -->
              <div class="grid grid-cols-2 gap-2.5 mb-4">
                {[
                  [es ? 'Modelo' : 'Model', s1.model],
                  [es ? 'Fase' : 'Stage', s1.stage],
                  [es ? 'Mercados' : 'Markets', s1.markets],
                ].map(([k, v]) => (
                  <div class="bg-slate-50 dark:bg-white/[0.03] rounded-lg px-2.5 py-2 col-span-1">
                    <p class="text-[9px] text-slate-400 uppercase tracking-wide mb-0.5">{k}</p>
                    <p class="text-[11px] text-slate-700 dark:text-slate-300 font-medium leading-tight">{v}</p>
                  </div>
                ))}
                <div class="bg-indigo-50 dark:bg-indigo-500/[0.08] rounded-lg px-2.5 py-2 border border-indigo-100 dark:border-indigo-500/20 col-span-1 flex items-center gap-1.5">
                  <svg class="w-3 h-3 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                  <p class="text-[10px] text-indigo-600 dark:text-indigo-400 font-medium leading-tight">{s1.ctxLabel}</p>
                </div>
              </div>
              <!-- Documents -->
              <p class="text-[9px] text-slate-400 uppercase tracking-wide mb-2">{es ? 'Documentos' : 'Documents'}</p>
              <div class="space-y-1.5">
                {s1.docs.map((doc) => (
                  <div class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg bg-slate-50 dark:bg-white/[0.03]">
                    <svg class="w-3 h-3 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    <span class="text-[11px] text-slate-600 dark:text-slate-400">{doc}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- ── SCREEN 2: AI Intake ── -->
          <div id="screen-1" class="hero-screen absolute inset-0 card-glass rounded-2xl overflow-hidden shadow-glow-lg" style="opacity:0;transform:translateY(16px);pointer-events:none;transition:opacity 0.5s ease,transform 0.5s ease">
            <!-- Chrome -->
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-slate-200 dark:border-white/[0.07] bg-slate-50/80 dark:bg-white/[0.025]">
              <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span><span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span></div>
              <span class="flex-1 text-center text-[10px] text-slate-400 font-mono">strategicdecision.ai — intake</span>
            </div>
            <!-- Content -->
            <div class="p-5 bg-white dark:bg-transparent h-full flex flex-col">
              <div class="flex items-center gap-2 mb-4">
                <img src="/logo-mark.svg" alt="" class="w-3.5 h-3.5" />
                <span class="text-[10px] text-indigo-500 dark:text-indigo-400 font-semibold uppercase tracking-wider">{s2.heading}</span>
              </div>
              <!-- Chat bubbles -->
              <div class="flex flex-col gap-3 flex-1">
                <!-- AI Q1 -->
                <div class="flex gap-2 items-start">
                  <div class="w-6 h-6 rounded-lg bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.9 20A9 9 0 104 16.1L2 22z"/></svg>
                  </div>
                  <div class="bg-slate-100 dark:bg-white/[0.06] rounded-xl rounded-tl-sm px-3 py-2 max-w-[85%]">
                    <p class="text-[11px] text-slate-700 dark:text-slate-300 leading-relaxed">{s2.q1}</p>
                  </div>
                </div>
                <!-- User A1 -->
                <div class="flex gap-2 items-start flex-row-reverse">
                  <div class="w-6 h-6 rounded-full bg-slate-200 dark:bg-white/[0.1] flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  </div>
                  <div class="bg-indigo-500 rounded-xl rounded-tr-sm px-3 py-2 max-w-[85%]">
                    <p class="text-[11px] text-white leading-relaxed">{s2.a1}</p>
                  </div>
                </div>
                <!-- AI Q2 -->
                <div class="flex gap-2 items-start">
                  <div class="w-6 h-6 rounded-lg bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.9 20A9 9 0 104 16.1L2 22z"/></svg>
                  </div>
                  <div class="bg-slate-100 dark:bg-white/[0.06] rounded-xl rounded-tl-sm px-3 py-2 max-w-[85%]">
                    <p class="text-[11px] text-slate-700 dark:text-slate-300 leading-relaxed">{s2.q2}</p>
                  </div>
                </div>
                <!-- Typing indicator -->
                <div class="flex items-center gap-2 mt-auto px-3 py-2 rounded-xl bg-indigo-50 dark:bg-indigo-500/[0.08] border border-indigo-200 dark:border-indigo-500/20">
                  <svg class="w-3 h-3 text-indigo-500 animate-spin-slow" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                  <span class="text-[11px] text-indigo-600 dark:text-indigo-300">{s2.typing}</span>
                  <span class="ml-auto text-[11px] text-indigo-400 font-mono animate-blink">|</span>
                </div>
              </div>
            </div>
          </div>

          <!-- ── SCREEN 3: Report generating ── -->
          <div id="screen-2" class="hero-screen absolute inset-0 card-glass rounded-2xl overflow-hidden shadow-glow-lg" style="opacity:0;transform:translateY(16px);pointer-events:none;transition:opacity 0.5s ease,transform 0.5s ease">
            <!-- Chrome -->
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-slate-200 dark:border-white/[0.07] bg-slate-50/80 dark:bg-white/[0.025]">
              <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span><span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span></div>
              <span class="flex-1 text-center text-[10px] text-slate-400 font-mono">strategicdecision.ai — report</span>
            </div>
            <!-- Content -->
            <div class="p-5 bg-white dark:bg-transparent">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <img src="/logo-mark.svg" alt="" class="w-3.5 h-3.5" />
                    <span class="text-[10px] text-indigo-500 dark:text-indigo-400 font-semibold uppercase tracking-wider">Strategic Report</span>
                  </div>
                  <h3 class="text-slate-900 dark:text-white font-bold text-sm leading-tight">{t.mockup.title}</h3>
                  <p class="text-slate-500 text-[11px] mt-0.5">{t.mockup.subtitle}</p>
                </div>
                <span class="badge text-[9px] whitespace-nowrap">Live</span>
              </div>
              <!-- Progress -->
              <div class="mb-4">
                <div class="flex justify-between items-center mb-1.5">
                  <span class="text-[11px] text-slate-500">{es ? 'Progreso' : 'Completion'}</span>
                  <span class="text-[11px] font-semibold text-indigo-500 dark:text-indigo-400">{t.mockup.progress}%</span>
                </div>
                <div class="h-1.5 bg-slate-100 dark:bg-white/[0.06] rounded-full overflow-hidden">
                  <div class="h-full rounded-full animate-gradient" style={`width:${t.mockup.progress}%;background:linear-gradient(90deg,#6366f1,#818cf8,#6366f1);background-size:200%`}></div>
                </div>
              </div>
              <!-- Sections -->
              <div class="space-y-2 mb-4">
                {t.mockup.sections.map((section) => (
                  <div class="flex items-center gap-2.5">
                    {section.done ? (
                      <span class="w-4 h-4 rounded-full bg-indigo-500/15 border border-indigo-500/40 flex items-center justify-center flex-shrink-0">
                        <svg class="w-2.5 h-2.5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                      </span>
                    ) : (
                      <span class="w-4 h-4 rounded-full border border-slate-300 dark:border-white/20 flex-shrink-0"><span class="block w-full h-full rounded-full bg-indigo-400/30 animate-pulse"></span></span>
                    )}
                    <span class={`text-[11px] ${section.done ? 'text-slate-700 dark:text-slate-300' : 'text-slate-400 dark:text-slate-500'}`}>{section.label}</span>
                  </div>
                ))}
              </div>
              <!-- Generating -->
              <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-indigo-50 dark:bg-indigo-500/[0.08] border border-indigo-200 dark:border-indigo-500/20">
                <svg class="w-3.5 h-3.5 text-indigo-500 animate-spin-slow" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                <span class="text-[11px] text-indigo-600 dark:text-indigo-300">{t.mockup.generating}</span>
                <span class="ml-auto text-[11px] text-indigo-400 font-mono animate-blink">|</span>
              </div>
            </div>
          </div>

        </div><!-- end screens wrapper -->

        <!-- Progress dots -->
        <div class="flex justify-center gap-2" id="screen-dots">
          {[0,1,2].map(i => (
            <button
              data-dot={i}
              aria-label={screenLabels[i]}
              class={`screen-dot rounded-full transition-all duration-300 ${i === 0 ? 'w-6 h-2 bg-indigo-500' : 'w-2 h-2 bg-slate-300 dark:bg-white/20'}`}
            ></button>
          ))}
        </div>

      </div><!-- end right col -->

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-slate-50 dark:from-[#05090f] to-transparent pointer-events-none" aria-hidden="true"></div>
</section>

<script>
(function () {
  const TOTAL = 3;
  const INTERVAL = 4500;

  const screens = Array.from({ length: TOTAL }, (_, i) => document.getElementById(`screen-${i}`));
  const tabs    = Array.from(document.querySelectorAll('.screen-tab'));
  const dots    = Array.from(document.querySelectorAll('.screen-dot'));

  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  function goTo(idx: number) {
    // Hide current
    const prev = screens[current];
    if (prev) {
      prev.style.opacity = '0';
      prev.style.transform = 'translateY(-12px)';
      (prev as HTMLElement).style.pointerEvents = 'none';
    }

    current = idx;

    // Show next
    const next = screens[current];
    if (next) {
      next.style.opacity = '1';
      next.style.transform = 'translateY(0)';
      (next as HTMLElement).style.pointerEvents = 'auto';
    }

    // Update tabs
    tabs.forEach((tab, i) => {
      const active = i === current;
      tab.classList.toggle('bg-indigo-500', active);
      tab.classList.toggle('text-white', active);
      tab.classList.toggle('shadow-glow-sm', active);
      tab.classList.toggle('bg-slate-100', !active);
      tab.classList.toggle('dark:bg-white/[0.05]', !active);
      tab.classList.toggle('text-slate-400', !active);
      tab.classList.toggle('dark:text-slate-500', !active);
      tab.setAttribute('aria-selected', String(active));
    });

    // Update dots
    dots.forEach((dot, i) => {
      const active = i === current;
      dot.classList.toggle('w-6', active);
      dot.classList.toggle('bg-indigo-500', active);
      dot.classList.toggle('w-2', !active);
      dot.classList.toggle('bg-slate-300', !active);
      dot.classList.toggle('dark:bg-white/20', !active);
    });
  }

  function startTimer() {
    timer = setInterval(() => goTo((current + 1) % TOTAL), INTERVAL);
  }

  function resetTimer() {
    if (timer) clearInterval(timer);
    startTimer();
  }

  // Tab clicks
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      goTo(Number((tab as HTMLElement).dataset.tab));
      resetTimer();
    });
  });

  // Dot clicks
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      goTo(Number((dot as HTMLElement).dataset.dot));
      resetTimer();
    });
  });

  // Start auto-advance
  startTimer();


})();
</script>
