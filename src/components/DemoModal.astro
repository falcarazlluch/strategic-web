---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

// ── UPDATE WHEN VIDEO IS READY ───────────────────────────────────────────────
const YOUTUBE_VIDEO_ID = ''; // e.g. 'dQw4w9WgXcQ'
// ────────────────────────────────────────────────────────────────────────────

// ── CHAPTER TIMESTAMPS (seconds) — update after recording ───────────────────
const TIMESTAMPS = [0, 45, 90, 135, 170, 230];
// ────────────────────────────────────────────────────────────────────────────

const hasVideo = YOUTUBE_VIDEO_ID !== '';
const APP_URL  = import.meta.env.PUBLIC_APP_URL ?? 'https://strategic-z6xl.vercel.app';

const copy = {
  en: {
    title:         'See how it works',
    sub:           'From company setup to executive report in under 10 minutes.',
    chaptersLabel: 'Jump to a step',
    close:         'Close',
    noVideoTitle:  'Demo video coming soon',
    noVideoSub:    'We are recording the full walkthrough. Check back shortly.',
    cta:           'Get Started',
    chapters: [
      { label: 'Company setup'      },
      { label: 'Problem definition' },
      { label: 'Strategic intake'   },
      { label: 'Report type'        },
      { label: 'Generation'         },
      { label: 'Refine with Aris'   },
    ],
  },
  es: {
    title:         'Cómo funciona',
    sub:           'De la configuración de empresa al informe ejecutivo en menos de 10 minutos.',
    chaptersLabel: 'Ir a un paso',
    close:         'Cerrar',
    noVideoTitle:  'Vídeo demo próximamente',
    noVideoSub:    'Estamos grabando el vídeo completo. Vuelve pronto.',
    cta:           'Empieza Ahora',
    chapters: [
      { label: 'Config. empresa'   },
      { label: 'Definir problema'  },
      { label: 'Intake IA'         },
      { label: 'Tipo de informe'   },
      { label: 'Generación'        },
      { label: 'Retoque con Aris'  },
    ],
  },
}[lang];
---

<!-- ── Overlay ───────────────────────────────────────────────────────────── -->
<div
  id="demo-modal-overlay"
  style="display:none;position:fixed;inset:0;z-index:9000;align-items:center;justify-content:center;padding:0.75rem;background:rgba(0,0,0,0.88);backdrop-filter:blur(4px)"
  aria-modal="true"
  role="dialog"
  aria-labelledby="demo-modal-title"
>
  <!-- Panel -->
  <div
    id="demo-modal-panel"
    style="position:relative;width:100%;max-width:56rem;max-height:92dvh;display:flex;flex-direction:column;border-radius:1rem;overflow:hidden;background:#0b1018;border:1px solid rgba(255,255,255,0.07);box-shadow:0 25px 60px rgba(0,0,0,0.7)"
  >
    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;padding:0.875rem 1.25rem;border-bottom:1px solid rgba(255,255,255,0.06);flex-shrink:0">
      <div>
        <h2 id="demo-modal-title" style="color:white;font-weight:700;font-size:1rem;line-height:1.3;margin:0">
          {copy.title}
        </h2>
        <p style="color:#64748b;font-size:0.75rem;margin:0.2rem 0 0">{copy.sub}</p>
      </div>
      <button
        id="close-demo-modal"
        aria-label={copy.close}
        style="margin-left:1rem;flex-shrink:0;padding:0.375rem;border-radius:0.5rem;color:#64748b;background:transparent;border:none;cursor:pointer;line-height:0;transition:color 0.15s,background 0.15s"
        onmouseenter="this.style.color='white';this.style.background='rgba(255,255,255,0.07)'"
        onmouseleave="this.style.color='#64748b';this.style.background='transparent'"
      >
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Video -->
    <div style="background:black;flex-shrink:0;width:100%">
      {hasVideo ? (
        <div id="demo-video-container" style="width:100%;aspect-ratio:16/9"></div>
      ) : (
        <div style="width:100%;aspect-ratio:16/9;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;background:linear-gradient(135deg,rgba(99,102,241,0.1) 0%,#0b1018 70%)">
          <div style="width:4rem;height:4rem;border-radius:9999px;display:flex;align-items:center;justify-content:center;background:rgba(99,102,241,0.14);border:1px solid rgba(99,102,241,0.3)">
            <svg width="28" height="28" fill="rgba(129,140,248,1)" viewBox="0 0 24 24" style="transform:translateX(2px)">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <div style="text-align:center">
            <p style="color:white;font-weight:600;font-size:0.875rem;margin:0">{copy.noVideoTitle}</p>
            <p style="color:#475569;font-size:0.75rem;margin:0.25rem 0 0">{copy.noVideoSub}</p>
          </div>
        </div>
      )}
    </div>

    <!-- Chapters strip -->
    <div style="border-top:1px solid rgba(255,255,255,0.06);padding:0.75rem 1rem 0.625rem;flex-shrink:0">
      <p style="font-size:0.625rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#475569;margin:0 0 0.625rem">
        {copy.chaptersLabel}
      </p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.375rem" class="demo-chapters-grid">
        {copy.chapters.map((ch, i) => (
          <button
            class="chapter-btn"
            data-idx={i}
            data-t={TIMESTAMPS[i]}
            type="button"
            style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.625rem;border-radius:0.625rem;background:rgba(255,255,255,0.04);border:1px solid transparent;cursor:pointer;text-align:left;transition:background 0.15s,border-color 0.15s;width:100%"
          >
            <span
              class="chapter-num"
              style="flex-shrink:0;width:1.375rem;height:1.375rem;border-radius:9999px;display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;background:rgba(255,255,255,0.06);color:#64748b;transition:background 0.15s,color 0.15s"
            >
              {i + 1}
            </span>
            <span
              class="chapter-label"
              style="font-size:0.7rem;font-weight:600;color:#94a3b8;line-height:1.2;transition:color 0.15s"
            >
              {ch.label}
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div style="padding:0.625rem 1rem 0.875rem;flex-shrink:0;border-top:1px solid rgba(255,255,255,0.06)">
      <a
        href={`${APP_URL}/register`}
        class="btn-primary"
        style="width:100%;justify-content:center;font-size:0.875rem;padding:0.625rem 1rem"
      >
        {copy.cta}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<!-- 3-col → 6-col on sm+ -->
<style>
  @media (min-width: 480px) {
    .demo-chapters-grid { grid-template-columns: repeat(6, 1fr) !important; }
  }
</style>

<script define:vars={{ YOUTUBE_VIDEO_ID, TIMESTAMPS, hasVideo }}>
(function () {
  const overlay     = document.getElementById('demo-modal-overlay');
  const closeBtn    = document.getElementById('close-demo-modal');
  const chapterBtns = Array.from(document.querySelectorAll('.chapter-btn'));

  let player       = null;
  let pollInterval = null;
  let playerReady  = false;
  let pendingOpen  = false;

  // ── Open / close ──────────────────────────────────────────────────────────
  function openModal() {
    if (!overlay) return;
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    if (hasVideo && !player) initYT();
  }

  function closeModal() {
    if (!overlay) return;
    overlay.style.display = 'none';
    document.body.style.overflow = '';
    stopPoll();
    if (player && playerReady) { try { player.pauseVideo(); } catch (_) {} }
  }

  closeBtn?.addEventListener('click', closeModal);

  // Close on backdrop click (click outside panel)
  overlay?.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });

  // Primary: custom event (from Hero bundled script)
  window.addEventListener('openDemoModal', openModal);

  // Fallback: direct document click listener (catches mobile reliably)
  document.addEventListener('click', function (e) {
    if (e.target && e.target.closest && e.target.closest('#hero-open-demo')) {
      openModal();
    }
  });

  // ── YouTube ───────────────────────────────────────────────────────────────
  function initYT() {
    if (window.YT && window.YT.Player) { createPlayer(); return; }
    if (!document.getElementById('yt-api-script')) {
      const tag = document.createElement('script');
      tag.id  = 'yt-api-script';
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);
    }
    pendingOpen = true;
  }

  const prevYTReady = window.onYouTubeIframeAPIReady;
  window.onYouTubeIframeAPIReady = function () {
    if (prevYTReady) prevYTReady();
    if (pendingOpen) { pendingOpen = false; createPlayer(); }
  };

  function createPlayer() {
    const container = document.getElementById('demo-video-container');
    if (!container || player) return;
    const div = document.createElement('div');
    div.id = 'yt-player-el';
    div.style.cssText = 'width:100%;height:100%';
    container.appendChild(div);
    player = new YT.Player('yt-player-el', {
      videoId: YOUTUBE_VIDEO_ID,
      width: '100%',
      height: '100%',
      playerVars: { autoplay: 1, rel: 0, modestbranding: 1, iv_load_policy: 3 },
      events: {
        onReady: function () { playerReady = true; },
        onStateChange: function (e) {
          if (e.data === 1) startPoll(); else stopPoll();
        },
      },
    });
  }

  // ── Chapters ──────────────────────────────────────────────────────────────
  chapterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      const t   = parseInt(btn.dataset.t   || '0', 10);
      const idx = parseInt(btn.dataset.idx || '0', 10);
      if (player && playerReady) { player.seekTo(t, true); player.playVideo(); }
      setActive(idx);
    });
  });

  function startPoll() {
    stopPoll();
    pollInterval = setInterval(function () {
      if (!player || !playerReady) return;
      try {
        const t = player.getCurrentTime();
        let active = 0;
        for (let i = TIMESTAMPS.length - 1; i >= 0; i--) {
          if (t >= TIMESTAMPS[i]) { active = i; break; }
        }
        setActive(active);
      } catch (_) {}
    }, 500);
  }

  function stopPoll() {
    if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
  }

  function setActive(idx) {
    chapterBtns.forEach(function (btn, i) {
      const num   = btn.querySelector('.chapter-num');
      const label = btn.querySelector('.chapter-label');
      const on    = i === idx;
      btn.style.background   = on ? 'rgba(99,102,241,0.12)' : 'rgba(255,255,255,0.04)';
      btn.style.borderColor  = on ? 'rgba(99,102,241,0.3)'  : 'transparent';
      if (num) {
        num.style.background = on ? '#6366f1' : 'rgba(255,255,255,0.06)';
        num.style.color      = on ? 'white'   : '#64748b';
      }
      if (label) {
        label.style.color = on ? 'white' : '#94a3b8';
      }
    });
  }

  setActive(0);
})();
</script>
