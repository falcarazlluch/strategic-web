};

const gradients = [
  'from-indigo-500 to-violet-500',
  'from-violet-500 to-purple-600',
  'from-blue-500 to-indigo-500',
  'from-indigo-400 to-blue-600',
  'from-emerald-500 to-teal-500',
  'from-amber-500 to-orange-500',
];
---

<section id="features" class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-dots-pattern opacity-40 dark:opacity-100 pointer-events-none" aria-hidden="true"></div>
  <div class="glow-blob w-[500px] h-[500px] bg-violet-500/[0.06] dark:bg-violet-600/[0.1] top-0 right-0" aria-hidden="true"></div>

  <div class="section-container relative z-10">
    <div class="text-center mb-16 reveal">
      <div class="badge mb-4" style="margin:0 auto 1rem;width:fit-content">{t.badge}</div>
      <h2 class="text-3xl sm:text-4xl xl:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-5">
        {t.headline}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">{t.subheadline}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {t.items.map((item, i) => (
        <div class={`card-glass p-6 reveal reveal-delay-${(i % 3) + 1}`}>
          <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${gradients[i]} flex items-center justify-center text-white mb-5 shadow-glow-sm flex-shrink-0`}>
            <Fragment set:html={icons[item.icon] ?? icons['brain']} />
          </div>
          <h3 class="text-slate-900 dark:text-white font-bold text-base mb-2">{item.title}</h3>
          <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
