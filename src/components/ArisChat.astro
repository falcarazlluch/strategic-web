---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
let API_URL = (import.meta.env.PUBLIC_API_URL ?? 'https://strategic-production.up.railway.app/api/v1').replace(/\/$/, '');
if (!API_URL.startsWith('http')) API_URL = `https://${API_URL}`;

const i18n = {
  es: {
    greeting: '¡Hola! Soy **Aris**, tu asistente en Strategic Decision.\n\n¿En qué puedo ayudarte hoy?',
    subtitle: 'Asistente de Strategic Decision',
    placeholder: 'Escribe tu pregunta...',
    error: 'No se pudo conectar con el asistente. Por favor, inténtalo de nuevo.',
    typing: 'Escribiendo...',
    suggestions: [
      '¿Cómo genero un informe estratégico?',
      '¿Qué funcionalidades incluye cada plan?',
      '¿Para qué sirve Aris en el informe?',
      '¿Cómo exporto a PDF o Word?',
      '¿Cómo empiezo a usar la plataforma?',
    ],
  },
  en: {
    greeting: 'Hi! I\'m **Aris**, your Strategic Decision assistant.\n\nHow can I help you today?',
    subtitle: 'Strategic Decision assistant',
    placeholder: 'Type your question...',
    error: 'Could not reach the assistant. Please try again.',
    typing: 'Typing...',
    suggestions: [
      'How do I generate a strategic report?',
      'What does each plan include?',
      'What is Aris used for in the report?',
      'How do I export to PDF or Word?',
      'How do I get started with the platform?',
    ],
  },
}

const t = i18n[lang];
---

<!-- Aris floating chat widget -->
<div id="aris-chat-root">

  <!-- Floating button — same MessageCircle icon as the app -->
  <button
    id="aris-open-btn"
    aria-label="Abrir Aris"
    style="
      position:fixed; bottom:1.5rem; right:1.5rem; z-index:9000;
      width:4rem; height:4rem; border-radius:9999px;
      background:#6366f1; color:white; border:none; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      box-shadow:0 8px 28px rgba(99,102,241,0.5);
      transition:transform 0.2s, opacity 0.2s, background 0.15s;
    "
    onmouseenter="this.style.background='#4f46e5'"
    onmouseleave="this.style.background='#6366f1'"
  >
    <!-- lucide MessageCircle -->
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="1.75"
         stroke-linecap="round" stroke-linejoin="round">
      <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>
    </svg>
  </button>

  <!-- Chat panel -->
  <div
    id="aris-panel"
    style="
      position:fixed; bottom:1.5rem; right:1.5rem; z-index:9001;
      width:380px; max-width:calc(100vw - 2rem); height:520px;
      border-radius:1rem; overflow:hidden;
      display:flex; flex-direction:column;
      background:#09090b; border:1px solid rgba(255,255,255,0.08);
      box-shadow:0 24px 60px rgba(0,0,0,0.5);
      transform:translateY(1rem); opacity:0; pointer-events:none;
      transition:transform 0.25s ease, opacity 0.25s ease;
    "
  >
    <!-- Header -->
    <div style="
      display:flex; align-items:center; gap:0.75rem;
      padding:0.75rem 1rem; background:#6366f1; flex-shrink:0;
    ">
      <!-- Aris icon -->
      <div style="
        width:2rem; height:2rem; border-radius:0.5rem; flex-shrink:0;
        background:rgba(255,255,255,0.2);
        display:flex; align-items:center; justify-content:center;
      ">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>
        </svg>
      </div>
      <div style="flex:1;min-width:0;">
        <p style="margin:0;font-size:0.875rem;font-weight:600;color:white;">Aris</p>
        <p style="margin:0;font-size:0.75rem;color:rgba(255,255,255,0.75);">{t.subtitle}</p>
      </div>
      <button id="aris-close-btn" aria-label="Cerrar" style="
        background:none; border:none; cursor:pointer; color:rgba(255,255,255,0.7);
        display:flex; align-items:center; justify-content:center;
        width:1.75rem; height:1.75rem; border-radius:50%; padding:0;
      ">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="aris-messages" style="
      flex:1; overflow-y:auto; padding:1rem;
      display:flex; flex-direction:column; gap:0.75rem;
      scrollbar-width:thin; scrollbar-color:rgba(255,255,255,0.1) transparent;
    "></div>

    <!-- Input -->
    <div style="
      border-top:1px solid rgba(255,255,255,0.08);
      padding:0.625rem 0.75rem;
      display:flex; gap:0.5rem; align-items:flex-end; flex-shrink:0;
    ">
      <textarea
        id="aris-input"
        placeholder={t.placeholder}
        rows="1"
        style="
          flex:1; resize:none; border-radius:0.75rem;
          border:1px solid rgba(255,255,255,0.12);
          background:rgba(255,255,255,0.05);
          color:#e4e4e7; padding:0.5rem 0.75rem;
          font-size:0.875rem; font-family:inherit; outline:none;
          max-height:6rem; line-height:1.5; scrollbar-width:none;
        "
      ></textarea>
      <button id="aris-send-btn" disabled aria-label="Enviar" style="
        width:2.25rem; height:2.25rem; border-radius:0.75rem; flex-shrink:0;
        background:#6366f1; border:none; cursor:not-allowed; color:white;
        display:flex; align-items:center; justify-content:center;
        transition:background 0.15s; opacity:0.4;
      ">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 2 11 13"/><path d="M22 2 15 22 11 13 2 9l20-7z"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ API_URL, greetingRaw: t.greeting, suggestions: t.suggestions, errorMsg: t.error, typingMsg: t.typing }}>
(function () {
  const panel    = document.getElementById('aris-panel')
  const openBtn  = document.getElementById('aris-open-btn')
  const closeBtn = document.getElementById('aris-close-btn')
  const msgBox   = document.getElementById('aris-messages')
  const input    = document.getElementById('aris-input')
  const sendBtn  = document.getElementById('aris-send-btn')

  let isStreaming = false
  let history     = []
  let abortCtrl   = null
  let initialized = false

  /* ── Markdown renderer ──────────────────────────────────────────────────── */
  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
  }

  function inline(text) {
    return esc(text)
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g,     '<em>$1</em>')
      .replace(/`(.+?)`/g,       '<code style="background:rgba(255,255,255,0.1);padding:0.1em 0.3em;border-radius:3px;font-family:monospace;font-size:0.83em">$1</code>')
  }

  function md(text) {
    const lines = text.split('\n')
    let html = '', inUl = false, inOl = false

    function closeLists() {
      if (inUl) { html += '</ul>'; inUl = false }
      if (inOl) { html += '</ol>'; inOl = false }
    }

    lines.forEach(line => {
      if (/^### /.test(line)) {
        closeLists()
        html += `<p style="font-weight:600;margin:0.4rem 0 0.2rem;color:#e4e4e7">${inline(line.slice(4))}</p>`
      } else if (/^## /.test(line)) {
        closeLists()
        html += `<p style="font-weight:700;margin:0.4rem 0 0.2rem;color:#f4f4f5">${inline(line.slice(3))}</p>`
      } else if (/^- /.test(line)) {
        if (!inUl) { closeLists(); html += '<ul style="margin:0.3rem 0;padding-left:1.1rem;list-style:disc;">'; inUl = true }
        html += `<li style="margin:0.1rem 0;line-height:1.55">${inline(line.slice(2))}</li>`
      } else if (/^\d+\. /.test(line)) {
        const m = line.match(/^\d+\. (.+)/)
        if (!inOl) { closeLists(); html += '<ol style="margin:0.3rem 0;padding-left:1.1rem;">'; inOl = true }
        html += `<li style="margin:0.1rem 0;line-height:1.55">${inline(m[1])}</li>`
      } else {
        closeLists()
        if (line.trim() === '') return
        html += `<p style="margin:0.15rem 0;line-height:1.6">${inline(line)}</p>`
      }
    })

    closeLists()
    return html
  }

  /* ── Bubble builder ─────────────────────────────────────────────────────── */
  function bubble(role, content, streaming) {
    const wrap = document.createElement('div')
    wrap.style.cssText = `display:flex;gap:0.5rem;align-items:flex-start;${role === 'user' ? 'flex-direction:row-reverse;' : ''}`

    const av = document.createElement('div')
    if (role === 'assistant') {
      av.style.cssText = 'width:1.75rem;height:1.75rem;border-radius:0.375rem;flex-shrink:0;background:rgba(99,102,241,0.25);border:1px solid rgba(99,102,241,0.4);display:flex;align-items:center;justify-content:center;'
      av.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>'
    } else {
      av.style.cssText = 'width:1.75rem;height:1.75rem;border-radius:9999px;flex-shrink:0;background:#3f3f46;display:flex;align-items:center;justify-content:center;'
      av.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>'
    }

    const bbl = document.createElement('div')
    bbl.style.cssText = `max-width:80%;border-radius:1rem;padding:0.5rem 0.75rem;font-size:0.875rem;line-height:1.55;${
      role === 'user'
        ? 'background:#6366f1;color:white;border-bottom-right-radius:0.25rem;'
        : 'background:rgba(255,255,255,0.06);color:#d4d4d8;border-bottom-left-radius:0.25rem;'
    }`

    if (streaming) {
      bbl.innerHTML = `<span style="display:flex;align-items:center;gap:0.4rem;color:#71717a">
        <svg class="aris-spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        ${typingMsg}</span>`
    } else if (role === 'user') {
      bbl.textContent = content
    } else {
      bbl.innerHTML = md(content)
    }

    wrap.appendChild(av)
    wrap.appendChild(bbl)
    msgBox.appendChild(wrap)
    msgBox.scrollTop = msgBox.scrollHeight
    return bbl
  }

  /* ── Suggestion chips ───────────────────────────────────────────────────── */
  function showSuggestions() {
    const wrap = document.createElement('div')
    wrap.id = 'aris-chips'
    wrap.style.cssText = 'display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.25rem;'
    suggestions.forEach(s => {
      const btn = document.createElement('button')
      btn.textContent = s
      btn.style.cssText = 'background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);color:#a1a1aa;border-radius:9999px;padding:0.25rem 0.75rem;font-size:0.75rem;cursor:pointer;font-family:inherit;transition:color 0.15s,border-color 0.15s;'
      btn.onmouseenter = () => { btn.style.color='#a5b4fc'; btn.style.borderColor='rgba(99,102,241,0.4)' }
      btn.onmouseleave = () => { btn.style.color='#a1a1aa'; btn.style.borderColor='rgba(255,255,255,0.12)' }
      btn.onclick = () => { wrap.remove(); sendMsg(s) }
      wrap.appendChild(btn)
    })
    msgBox.appendChild(wrap)
    msgBox.scrollTop = msgBox.scrollHeight
  }

  /* ── Send ───────────────────────────────────────────────────────────────── */
  async function sendMsg(text) {
    const content = (text ?? input.value).trim()
    if (!content || isStreaming) return

    input.value = ''
    input.style.height = 'auto'
    setBtn(false)

    document.getElementById('aris-chips')?.remove()
    history.push({ role: 'user', content })
    bubble('user', content, false)

    isStreaming = true
    const streamBbl = bubble('assistant', '', true)
    abortCtrl = new AbortController()

    try {
      const res = await fetch(`${API_URL}/help/public-chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: content, history: history.slice(-10) }),
        signal: abortCtrl.signal,
      })

      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      if (!res.body) throw new Error('No body')

      const reader = res.body.getReader()
      const decoder = new TextDecoder()
      let buf = '', acc = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        buf += decoder.decode(value, { stream: true })
        const lines = buf.split('\n')
        buf = lines.pop() ?? ''
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue
          const data = line.slice(6)
          if (data === '[DONE]') break
          acc += data
          streamBbl.innerHTML = md(acc)
          msgBox.scrollTop = msgBox.scrollHeight
        }
      }

      history.push({ role: 'assistant', content: acc })
    } catch (err) {
      if (err.name !== 'AbortError') {
        streamBbl.innerHTML = `<span style="color:#f87171">${errorMsg}</span>`
      }
    } finally {
      isStreaming = false
      abortCtrl = null
      setBtn(input.value.trim().length > 0)
    }
  }

  /* ── Open / close ───────────────────────────────────────────────────────── */
  function openChat() {
    panel.style.opacity = '1'
    panel.style.transform = 'translateY(0)'
    panel.style.pointerEvents = 'auto'
    openBtn.style.opacity = '0'
    openBtn.style.pointerEvents = 'none'
    openBtn.style.transform = 'scale(0.75)'

    if (!initialized) {
      initialized = true
      const bbl = bubble('assistant', '', false)
      bbl.innerHTML = md(greetingRaw)
      showSuggestions()
    }

    setTimeout(() => input.focus(), 150)
  }

  function closeChat() {
    panel.style.opacity = '0'
    panel.style.transform = 'translateY(1rem)'
    panel.style.pointerEvents = 'none'
    openBtn.style.opacity = '1'
    openBtn.style.pointerEvents = 'auto'
    openBtn.style.transform = 'scale(1)'
    abortCtrl?.abort()
  }

  /* ── Input ──────────────────────────────────────────────────────────────── */
  function setBtn(enabled) {
    sendBtn.disabled = !enabled
    sendBtn.style.opacity = enabled ? '1' : '0.4'
    sendBtn.style.cursor = enabled ? 'pointer' : 'not-allowed'
  }

  input.addEventListener('input', () => {
    input.style.height = 'auto'
    input.style.height = Math.min(input.scrollHeight, 96) + 'px'
    setBtn(input.value.trim().length > 0 && !isStreaming)
  })

  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg() }
  })

  sendBtn.addEventListener('click', () => sendMsg())
  openBtn.addEventListener('click', openChat)
  closeBtn.addEventListener('click', closeChat)

  /* spin animation */
  const s = document.createElement('style')
  s.textContent = '@keyframes aris-s{to{transform:rotate(360deg)}}.aris-spin{animation:aris-s 1s linear infinite;transform-origin:center}'
  document.head.appendChild(s)
})()
</script>
